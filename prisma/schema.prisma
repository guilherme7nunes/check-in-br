// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  phone         String?
  role          UserRole  @default(USER)
  stripeAccountId String?
  stripeConnected Boolean   @default(false)
  
  accounts      Account[]
  sessions      Session[]
  events        Event[]   @relation("UserEvents")
  orders        Order[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum UserRole {
  USER
  ORGANIZER
  ADMIN
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime // Start Date
  endDate     DateTime? // End Date
  showTimes   Boolean  @default(true)
  location    String
  locationType String  @default("PHYSICAL") // PHYSICAL, ONLINE, TO_DEFINE
  image       String?
  schedule    String?  // Programação do evento
  organizerId String
  organizer   User     @relation("UserEvents", fields: [organizerId], references: [id])
  
  ticketTypes TicketType[]
  addons      Addon[]
  orders      Order[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TicketType {
  id          String   @id @default(cuid())
  name        String   // e.g., "Individual", "Duplo"
  price       Decimal
  capacity    Int?
  isGroup     Boolean  @default(false)
  groupSize   Int      @default(1)
  customFields Json?   // [{ label: "Tamanho de Camiseta", required: true }]
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  
  tickets     Ticket[]
}

model Addon {
  id          String   @id @default(cuid())
  name        String
  price       Decimal
  category    String   // MEAL, TRANSPORT, OTHER
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id])
  
  ticketAddons TicketAddon[]
}

model Order {
  id              String   @id @default(cuid())
  total           Decimal
  status          String   @default("PENDING") // PENDING, PAID, CANCELLED
  stripeSessionId String?
  buyerId         String
  buyer           User     @relation(fields: [buyerId], references: [id])
  eventId         String
  event           Event    @relation(fields: [eventId], references: [id])
  
  tickets         Ticket[]
  createdAt       DateTime @default(now())
}

model Ticket {
  id            String   @id @default(cuid())
  qrCode        String?  @unique
  attendeeName  String
  attendeeEmail String?
  customData    Json?    // { "Instagram": "@user", "Idade": "25" }
  status        String   @default("PENDING") // PENDING, USED
  
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  ticketTypeId  String
  ticketType    TicketType @relation(fields: [ticketTypeId], references: [id])
  
  addons        TicketAddon[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TicketAddon {
  id        String @id @default(cuid())
  ticketId  String
  ticket    Ticket @relation(fields: [ticketId], references: [id])
  addonId   String
  addon     Addon  @relation(fields: [addonId], references: [id])
  
  @@unique([ticketId, addonId])
}
